# Enable mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 301 redirect old /products/ URLs to flat top-level URLs (SEO preservation)
  RewriteRule ^products/(.+)$ /$1 [R=301,L,QSA]

  # 301 redirect old dashed category URLs to new single-word URLs
  RewriteRule ^medical-equipment$ /medical [R=301,L,QSA]
  RewriteRule ^microbiology-biotechnology$ /microbiology [R=301,L,QSA]
  RewriteRule ^laboratory-chemicals$ /chemicals [R=301,L,QSA]
  RewriteRule ^water-analysis$ /water [R=301,L,QSA]
  RewriteRule ^laboratory-testing$ /testing [R=301,L,QSA]
  RewriteRule ^safety-products$ /safety [R=301,L,QSA]
  RewriteRule ^waste-water-filtration$ /wastewater [R=301,L,QSA]
  RewriteRule ^lab-equipment$ /labequipment [R=301,L,QSA]
  RewriteRule ^automobile-supplies$ /automobile [R=301,L,QSA]
  RewriteRule ^chromatography-consumables$ /chromatography [R=301,L,QSA]
  RewriteRule ^equipment-quality-control$ /qualitycontrol [R=301,L,QSA]
  RewriteRule ^hach-instruments$ /hach [R=301,L,QSA]
  RewriteRule ^laboratory-material-testing$ /materialtesting [R=301,L,QSA]

  # Serve XML files directly (sitemap, XSL, etc.)
  RewriteRule ^.*\.xml$ - [L]

  # Allow direct access to existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route API requests to api.php (both /api/ and /api.php/ patterns)
  RewriteRule ^api\.php/(.*)$ api.php [QSA,L]
  RewriteRule ^api/(.*)$ api.php [QSA,L]
  RewriteRule ^api\.php$ - [L]

  # Route all other requests to index.html (SPA)
  # Note: 404 pages are marked with noindex meta tag in React component
  # to prevent indexing of non-existent content as valid pages
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  # Prevent access to sensitive files
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP configuration
<IfModule mod_php.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 10M
  php_value memory_limit 256M
  php_value max_execution_time 300
</IfModule>

# Deny access to sensitive files
<FilesMatch "(\.env|\.env\..*|\.htaccess|config\.php|migrations\.sql|setup-admin\.php|Database\.php)$">
  Deny from all
</FilesMatch>

# Allow access to uploads directory
<Directory "uploads">
  Allow from all
  AddType image/jpeg .jpg
  AddType image/jpeg .jpeg
  AddType image/png .png
  AddType image/gif .gif
  AddType application/pdf .pdf
</Directory>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  
  # JavaScript & CSS
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  
  # HTML
  ExpiresByType text/html "access plus 1 hour"
  
  # Default
  ExpiresDefault "access plus 2 days"
</IfModule>
